guarantee safe [no_harmful_content:halt]
guarantee cited ([sources_attached] && [quotes_verified:2])
guarantee approved ({editor_signed_off:skip} || #{quality_model:3})

workflow "research" @always safe
    | @human "What topic?"
    | @human "Any constraints or target audience?"
    | search_web
    | collect_sources
    | extract_quotes
    | summarize style=([relevant:3] && [concise:halt])
    | @llm "Classify as technical or general"
    | @branch
        -when "technical"
            | @llm "Write detailed analysis"
            | @loop
                | @human "Is this good enough?"
                -until "yes"
        -when "general"
            | @llm "Write brief summary"
        -else
            | @llm "Write overview"
    | @unordered
        -step "format citations"
            | format_citations
        -step "generate bibliography"
            | generate_bibliography
        -step "archive sources"
            | archive_sources
    | @fork refs @call check_references
    | @fork refs @call verify_sources
    | @join refs
    | final_review gate=(![needs_revision] && {approved:skip})
    | @call send_report
    | email to="user"

workflow "publish" @always safe @always cited
    | @call research
    | draft_post channel="blog" audience="developers"
    | rewrite_for_clarity gate=([clear] && ![too_long])
    | @branch
        -when "launch"
            | prepare_launch_assets
            | @inline social_teaser
        -when "newsletter"
            | draft_newsletter subject="Weekly research digest"
        -else
            | save_draft
    | @loop
        | @human "Approve for publishing?"
        -until "yes"
    | publish_post

workflow "social_teaser" @always safe
    | generate_teasers gate=([punchy] && [accurate])
    | select_variant strategy="best_engagement"
    | schedule_posts platform="x"
